<apex:page controller="ProjectCompletionFormPdfController"
           standardStylesheets="false"
           showHeader="false"
           sidebar="false"
           cache="false"
           renderAs="pdf">
    <table cellpadding="0" cellspacing="0" border="0" width="560" align="center"
           style="border-collapse:collapse; color:#080707; font-family:'Times New Roman', Times, serif; font-size:14px; line-height:1.35; margin-top:36px;">
        <tr>
            <td align="center" style="padding:0 0 18px 0; text-align:center;">
                <buildertek:DisplayImageInTemplate />
            </td>
        </tr>
        <tr>
            <td align="center" style="font-size:24px; font-weight:bold; line-height:1.18; padding:0 0 36px 0; text-align:center;">
                Project Completion Form
            </td>
        </tr>
        <tr>
            <td style="padding:0 0 18px 0;">
                <table cellpadding="0" cellspacing="0" border="0" width="560" align="center"
                       style="border-collapse:collapse; color:#080707; font-family:'Times New Roman', Times, serif; font-size:14px;">
                    <tr>
                        <td width="250" style="padding:0 8px 0 0; text-align:left;">Name of the Client:</td>
                        <td width="310" style="border-bottom:1px solid #080707; padding:0 6px 3px 6px; text-align:left;">
                            <apex:outputText value="{!signerName}"/>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
        <tr>
            <td style="padding:0 0 26px 0;">
                <table cellpadding="0" cellspacing="0" border="0" width="560" align="center"
                       style="border-collapse:collapse; color:#080707; font-family:'Times New Roman', Times, serif; font-size:14px;">
                    <tr>
                        <td width="52" style="padding:0 8px 0 0; text-align:left;">Phone:</td>
                        <td width="170" style="border-bottom:1px solid #080707; padding:0 6px 3px 6px; text-align:left;">
                            <apex:outputText value="{!signerPhone}"/>
                        </td>
                        <td width="50" style="padding:0 8px 0 28px; text-align:left;">Email:</td>
                        <td width="290" style="border-bottom:1px solid #080707; padding:0 6px 3px 6px; text-align:left;">
                            <apex:outputText value="{!signerEmail}"/>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
        <tr>
            <td style="font-size:15px; line-height:1.45; padding:0 0 64px 0; text-align:left;">
                I attest that the accessible home modifications performed on my home by Home Builders Foundation or their subcontractors through their home modification program is complete and to my satisfaction. Now that the work is complete, I understand that the modifications made by the HBF (including but not limited to upkeep and maintenance) are now solely my responsibility.
            </td>
        </tr>
        <tr>
            <td>
                <table cellpadding="0" cellspacing="0" border="0" width="560" align="center"
                       style="border-collapse:collapse; color:#080707; font-family:'Times New Roman', Times, serif; font-size:14px;">
                    <tr>
                        <td width="350" height="86" style="border-bottom:1px solid #080707; vertical-align:bottom; padding:0 6px 4px 6px;">
                            <apex:outputPanel rendered="{!hasSignature}" layout="none">
                                <apex:image url="{!signatureImageUrl}" alt="Signature" style="display:block; height:auto; width:320px;"/>
                            </apex:outputPanel>
                        </td>
                        <td width="40">&nbsp;</td>
                        <td width="170" height="86" style="border-bottom:1px solid #080707; vertical-align:bottom; padding:0 6px 4px 6px; text-align:left;">
                            <apex:outputText value="{!signedDateDisplay}"/>
                        </td>
                    </tr>
                    <tr>
                        <td style="font-size:15px; padding-top:7px; text-align:left;">Signature</td>
                        <td>&nbsp;</td>
                        <td style="font-size:15px; padding-top:7px; text-align:left;">Date</td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</apex:page>
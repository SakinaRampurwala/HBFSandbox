<apex:page controller="ProjectCompletionFormController"
           action="{!initialize}"
           standardStylesheets="false"
           applyHtmlTag="false"
           applyBodyTag="false"
           showHeader="false"
           cache="false"
           docType="html-5.0">
    <html>
    <head>
        <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
        <style>
            body {
                background: #f7f7f7;
                margin: 0;
            }

            .pc-form-document {
                color: #080707;
                font-family: Georgia, "Times New Roman", serif;
                font-size: 18px;
                line-height: 1.35;
            }

            .pc-form-page {
                background: #fff;
                box-sizing: border-box;
                margin: 24px auto;
                max-width: 940px;
                min-height: 920px;
                padding: 48px 56px;
            }

            .pc-brand {
                margin: 0 auto 32px auto;
                text-align: center;
                width: 430px;
            }

            .pc-brand img {
                height: auto !important;
                max-width: 100%;
            }

            .pc-title {
                font-size: 28px;
                font-weight: bold;
                margin: 0 0 44px 0;
                text-align: center;
            }

            .pc-attestation {
                font-size: 20px;
                line-height: 1.45;
                margin: 34px 0 72px 0;
            }

            .pc-field-table {
                border-collapse: collapse;
                margin-bottom: 20px;
                width: 100%;
            }

            .pc-field-caption {
                color: #2f2f2f;
                font-size: 15px;
                font-weight: bold;
                padding: 0 12px 6px 0;
                white-space: nowrap;
            }

            .pc-field-value-box {
                background: #fbfbfb;
                border: 1px solid #b7b7b7;
                border-radius: 3px;
                font-size: 16px;
                min-height: 22px;
                padding: 8px 10px;
            }

            .pc-signature-section {
                margin-top: 30px;
                width: 100%;
            }

            .pc-signature-label {
                font-size: 16px;
                font-weight: bold;
                margin-bottom: 8px;
            }

            .pc-signature-pad-wrap {
                background: #fff;
                border: 2px solid #444;
                border-radius: 4px;
                padding: 8px;
            }

            .pc-signature-canvas {
                background: #fff;
                display: block;
                height: 230px;
                width: 100%;
            }

            .pc-date-row {
                margin-top: 22px;
                text-align: right;
            }

            .pc-date-label {
                display: inline-block;
                font-size: 16px;
                font-weight: bold;
                margin-right: 12px;
            }

            .pc-date-value {
                border-bottom: 1px solid #080707;
                display: inline-block;
                font-size: 18px;
                min-width: 180px;
                padding: 0 8px 4px 8px;
                text-align: left;
            }

            .pc-date-help {
                color: #555;
                font-family: Arial, Helvetica, sans-serif;
                font-size: 13px;
                margin-top: 4px;
                text-align: right;
            }


            .message {
                border-radius: 4px;
                font-family: Arial, Helvetica, sans-serif;
                font-size: 16px;
                margin: 24px 0;
                padding: 16px;
                text-align: center;
            }

            .success {
                background: #eaf8ef;
                color: #1f6f3d;
            }

            .error {
                background: #fdecea;
                color: #ba0517;
            }

            .actions {
                font-family: Arial, Helvetica, sans-serif;
                margin-top: 36px;
                text-align: center;
            }

            button {
                border: 1px solid #747474;
                border-radius: 4px;
                cursor: pointer;
                font-family: Arial, Helvetica, sans-serif;
                font-size: 15px;
                margin: 0 4px;
                padding: 9px 18px;
            }

            .primary {
                background: #0176d3;
                border-color: #0176d3;
                color: #fff;
            }

            #signatureError {
                margin: 16px auto 0 auto;
                max-width: 420px;
            }

            @media (max-width: 720px) {
                .pc-form-page {
                    margin: 0;
                    padding: 28px 18px;
                }

                .pc-brand {
                    width: 100%;
                }

                .pc-field-table,
                .pc-field-table tbody,
                .pc-field-table tr,
                .pc-field-table td {
                    display: block;
                    width: 100%;
                }

                .pc-field-caption {
                    padding: 0 0 6px 0;
                }

                .pc-field-value-box {
                    box-sizing: border-box;
                    margin-bottom: 14px;
                    width: 100%;
                }

                .pc-date-row,
                .pc-date-help {
                    text-align: left;
                }

                .pc-date-value {
                    box-sizing: border-box;
                    margin-top: 8px;
                    width: 100%;
                }
            }
        </style>
    </head>
    <body>
        <div class="pc-form-document">
            <div class="pc-form-page">
                <div class="pc-brand">
                    <buildertek:DisplayImageInTemplate />
                </div>

                <div class="pc-title">Project Completion Form</div>

                <apex:outputPanel rendered="{!OR(isSubmitted, isAlreadyComplete, hasError)}" layout="block" styleClass="{!displayMessageClass}">
                    <apex:outputText value="{!message}"/>
                </apex:outputPanel>

                <apex:outputPanel rendered="{!canSign}">
                    <apex:form id="completionForm">
                        <table class="pc-field-table">
                            <tr>
                                <td class="pc-field-caption">Name of the Client</td>
                            </tr>
                            <tr>
                                <td class="pc-field-value-box">
                                    <apex:outputText value="{!signerName}"/>
                                </td>
                            </tr>
                        </table>

                        <table class="pc-field-table">
                            <tr>
                                <td class="pc-field-caption" style="width:48%;">Phone</td>
                                <td style="width:4%;"></td>
                                <td class="pc-field-caption" style="width:48%;">Email</td>
                            </tr>
                            <tr>
                                <td class="pc-field-value-box" style="width:48%;">
                                    <apex:outputText value="{!signerPhone}"/>
                                </td>
                                <td style="width:4%;"></td>
                                <td class="pc-field-value-box" style="width:48%;">
                                    <apex:outputText value="{!signerEmail}"/>
                                </td>
                            </tr>
                        </table>

                        <p class="pc-attestation">
                            I attest that the accessible home modifications performed on my home by Home Builders Foundation or their subcontractors through their home modification program is complete and to my satisfaction. Now that the work is complete, I understand that the modifications made by the HBF (including but not limited to upkeep and maintenance) are now solely my responsibility.
                        </p>

                        <div class="pc-signature-section">
                            <div class="pc-signature-label">Signature</div>
                            <div class="pc-signature-pad-wrap">
                                <canvas id="signatureCanvas" class="pc-signature-canvas"></canvas>
                            </div>
                            <div class="pc-date-row">
                                <span class="pc-date-label">Date</span>
                                <span class="pc-date-value">
                                    <apex:outputText value="{!currentDateDisplay}"/>
                                </span>
                            </div>
                            <div class="pc-date-help">Today's date is recorded when you submit this form.</div>
                        </div>

                        <apex:inputHidden value="{!imageContent}" id="imageContentInput"/>
                        <apex:commandButton action="{!submitProjectCompletion}" id="submitButton" value="Submit" style="display:none;"/>

                        <div class="actions">
                            <button type="button" onclick="clearSignature()">Clear Signature</button>
                            <button type="button" class="primary" onclick="submitSignature()">Submit</button>
                            <div id="signatureError" class="message error" style="display:none;">Signature is required.</div>
                        </div>
                    </apex:form>
                </apex:outputPanel>
            </div>
        </div>

        <script>
            var canvas = document.getElementById('signatureCanvas');
            var context;
            var isDrawing = false;

            function resizeCanvas() {
                if (!canvas) {
                    return;
                }
                var rect = canvas.getBoundingClientRect();
                var ratio = Math.max(window.devicePixelRatio || 1, 1);
                canvas.width = Math.floor(rect.width * ratio);
                canvas.height = Math.floor(rect.height * ratio);
                context = canvas.getContext('2d');
                context.setTransform(ratio, 0, 0, ratio, 0, 0);
                context.lineWidth = 2;
                context.lineCap = 'round';
                context.strokeStyle = '#032d60';
            }

            function getPoint(event) {
                var rect = canvas.getBoundingClientRect();
                var source = event.touches && event.touches.length ? event.touches[0] : event;
                return {
                    x: source.clientX - rect.left,
                    y: source.clientY - rect.top
                };
            }

            function startDrawing(event) {
                event.preventDefault();
                isDrawing = true;
                var point = getPoint(event);
                context.beginPath();
                context.moveTo(point.x, point.y);
            }

            function draw(event) {
                if (!isDrawing) {
                    return;
                }
                event.preventDefault();
                var point = getPoint(event);
                context.lineTo(point.x, point.y);
                context.stroke();
            }

            function stopDrawing(event) {
                if (!isDrawing) {
                    return;
                }
                if (event) {
                    event.preventDefault();
                }
                isDrawing = false;
                context.closePath();
            }

            function hasSignature() {
                var pixels = context.getImageData(0, 0, canvas.width, canvas.height).data;
                for (var index = 3; index < pixels.length; index += 4) {
                    if (pixels[index] !== 0) {
                        return true;
                    }
                }
                return false;
            }

            function clearSignature() {
                context.clearRect(0, 0, canvas.width, canvas.height);
                document.getElementById('signatureError').style.display = 'none';
            }

            function submitSignature() {
                if (!hasSignature()) {
                    document.getElementById('signatureError').style.display = 'block';
                    return;
                }

                var image = canvas.toDataURL('image/png').split(',')[1];
                document.getElementById('{!$Component.completionForm.imageContentInput}').value = image;
                document.getElementById('{!$Component.completionForm.submitButton}').click();
            }

            if (canvas) {
                resizeCanvas();
                canvas.addEventListener('mousedown', startDrawing);
                canvas.addEventListener('mousemove', draw);
                canvas.addEventListener('mouseup', stopDrawing);
                canvas.addEventListener('mouseleave', stopDrawing);
                canvas.addEventListener('touchstart', startDrawing, { passive: false });
                canvas.addEventListener('touchmove', draw, { passive: false });
                canvas.addEventListener('touchend', stopDrawing, { passive: false });
                window.addEventListener('resize', resizeCanvas);
            }
        </script>
    </body>
    </html>
</apex:page>
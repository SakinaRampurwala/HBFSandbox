<!-- CUSTOM:  version developed to support customized donation amounts and labels. cache="fales enabled for testing" -->
<apex:page showHeader="false" controller="css_frm.donationManagerExtensionJS" standardStylesheets="false" sidebar="false" applyHtmlTag="false" cache="false" applyBodyTag="false" docType="html-5.0">
  <!-- Spring '20 V1.50000    -->
<html xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" lang="en"> 
<head>
  <meta charset="utf-8" />
  <meta http-equiv="x-ua-compatible" content="ie=edge" />
  <title id="tab-title" >donationManager by cloudStack</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <!-- Standard and cascaded custom style sheets -->
  <apex:slds />
  <link rel="stylesheet" href="" id="customCSS"/>
</head>

<body> 
<!-- REQUIRED SLDS WRAPPER -->
  <div class="slds-scope">
    <!-- Error message area --> 
    <div id="responseErrors"/>
 
    <!-- donorInformationPage -->  
    <div id="donorInformationPage">
      <div class="myapp slds-p-horizontal--medium">

        <!-- Contact / Account Search -->
        <div id="contactLookupSection" class="slds-form-element">
          <div class="slds-form-element__control">
            <div class="slds-combobox_container slds-m-top--small slds-has-object-switcher slds-has-input-focus">
              <div class="slds-combobox slds-dropdown-trigger slds-dropdown-trigger_click slds-is-open" aria-expanded="true" aria-haspopup="listbox" role="combobox">
                <div class="slds-combobox__form-element slds-input-has-icon slds-input-has-icon_right">
                  <input type="text" class="slds-input slds-combobox__input" id="input-donorLookup" aria-autocomplete="list" aria-controls="listbox-unique-id" autocomplete="off" role="textbox" placeholder="Search for existing Contact/Account" onkeyup="searchContacts('donor','All')">
                  <span class="slds-icon_container slds-icon-utility-search slds-input__icon slds-input__icon_right" title="Description of icon when needed">
                    <svg class="slds-icon slds-icon slds-icon_x-small slds-icon-text-default" aria-hidden="true">
                      <use xlink:href="{!URLFOR($Asset.SLDS,'assets/icons/utility-sprite/svg/symbols.svg#search')}" ></use>
                    </svg>
                    <span class="slds-assistive-text">Description of icon</span>
                  </span>
                  </input>
                </div>
                <div id="donor-listbox" role="listbox">
                  <ul id="donor-list" class="slds-listbox slds-listbox_vertical slds-dropdown slds-dropdown_fluid" role="presentation">
                  </ul>
                </div> <!-- end listbox -->
              </div> <!-- end combobox -->
            </div> <!-- end combobox container -->
          </div> <!-- end form-element control -->
        </div> <!-- end form-element -->
        <!-- end Contact / Account Search -->

        <div class="slds-form--stacked slds-m-top--small">
          <fieldset class="slds-form--compound " id="donorInformationFields">
            <legend id="label-donorType" class="slds-form-element__legend slds-form-element__label slds-text-title--caps ">This gift is from an</legend>
            <div class="slds-form-element__control">
              <div class="slds-radio_button-group">
                <span class="slds-button slds-radio_button">
                  <input type="radio" name="donorTypeOptions" id="input-individual" value="individual" checked="true">
                  <label class="slds-radio_button__label" for="input-individual"> <span id="label-individual" class="slds-radio_faux">Individual</span> </label> </input>
                </span>
                <span class="slds-button slds-radio_button">
                  <input type="radio" name="donorTypeOptions" id="input-organization" value="organization"> 
                  <label class="slds-radio_button__label" for="input-organization"> <span id="label-organization" class="slds-radio_faux">Organization</span> </label> </input>
                </span>
              </div>
            </div>
          
            <div id="section-organizationName">
              <legend id="label-organizationName" class="slds-form-element__label slds-text-title--caps slds-m-top--small">Company Information</legend>
              <div class="slds-form-element__row slds-grid--pull-padded">
                <div class="slds-p-horizontal--small slds-size--1-of-1">
                  <input type="text" id="input-organizationName" class="slds-input" placeholder="Company Name"/>
                </div>
              </div>   
            </div>  

            <!-- Individual Donor Name -->
            <div id="individual-contact-info">
              <legend id="label-donorInfo" class="slds-form-element__label slds-text-title--caps slds-m-top--small">Donor Information</legend>
              <div class="slds-form-element__group slds-form--inline " >
                <div class="slds-form-element__row slds-grid--pull-padded" id="element-donor-fName">
                  <div class="slds-p-horizontal--small slds-size--1-of-2 slds-medium-size--1-of-2 slds-large-size--1-of-2">             
                    <input type="text" id="input-donor-fName" class="slds-input" placeholder="First Name" />
                  </div>
                  <div class="slds-p-horizontal--small slds-size--1-of-2 slds-medium-size--1-of-2 slds-large-size--1-of-2">
                    <input type="text" id="input-donor-lName" class="slds-input" placeholder="Last Name" />        
                  </div>
                </div>
              </div>
              <div class="slds-form-element__row slds-grid--pull-padded">
                <div class="slds-p-horizontal--small slds-size--1-of-1">
                  <input type="text" id="input-donor-eMail" class="slds-input" placeholder="Email" />
                </div>
              </div>
            </div>

            <div class="slds-form-element__group slds-form--inline">
              <div class="slds-form-element__row slds-grid--pull-padded">
                <div class="slds-p-horizontal--small slds-size--1-of-1 ">
                  <input type="text" id="input-donor-street" class="slds-input" placeholder="Street Address" />
                </div>
              </div>
              <div class="slds-form-element__row slds-grid--pull-padded">
                <div class="slds-p-horizontal--small slds-size--1-of-2 slds-medium-size--1-of-2 slds-large-size--1-of-2">
                  <input type="text" id="input-donor-city" class="slds-input" placeholder="City" />
                </div>
                <div class="slds-p-horizontal--small slds-size--1-of-2 slds-medium-size--1-of-2 slds-large-size--1-of-2">
                  <input type="text" id="input-donor-state" class="slds-input" placeholder="Province/State" />
                </div>
              </div>
              <div class="slds-form-element__row slds-grid--pull-padded">
                <div class="slds-p-horizontal--small slds-size--1-of-2 slds-medium-size--1-of-2 slds-large-size--1-of-2">
                  <input type="text" id="input-donor-zip" class="slds-input" placeholder="Postal/Zip Code" />
                </div>
              </div>
              <div class="slds-form-element__row slds-grid--pull-padded">
                <div class="slds-p-horizontal--small slds-size--1-of-2 slds-medium-size--1-of-2 slds-large-size--1-of-2">
                  <input type="text" id="input-donor-phone" class="slds-input" placeholder="Phone" />
                </div>
              </div>
            </div>

            <!-- Organization Contact Information -->
            <div id="organization-contact-info">
              <legend id="label-orgContact" class="slds-form-element__label slds-text-title--caps slds-m-top--small">Contact Name</legend>
              <div class="slds-form-element__group slds-form--inline " >
                <div class="slds-form-element__row slds-grid--pull-padded">
                  <div class="slds-p-horizontal--small slds-size--1-of-2 slds-medium-size--1-of-2 slds-large-size--1-of-2">             
                    <input type="text" id="input-orgContact-fName" class="slds-input" placeholder="First Name"/>
                  </div>
                  <div class="slds-p-horizontal--small slds-size--1-of-2 slds-medium-size--1-of-2 slds-large-size--1-of-2">
                    <input type="text" id="input-orgContact-lName" class="slds-input" placeholder="Last Name"/>        
                  </div>
                </div>
              </div>
              <!-- <legend class="slds-form-element__label slds-text-title--caps">Email</legend> -->
              <div class="slds-form-element__row slds-grid--pull-padded">
                <div class="slds-p-horizontal--small slds-size--1-of-1">
                  <input type="text" id="input-orgContact-eMail" class="slds-input" placeholder="Email Address"/>
                </div>
              </div>
            </div>

            <!-- Newsletter Opt in -->
            <div data-reactroot="" class="slds-form-element slds-m-top--medium">
              <div class="slds-form-element__control">
                <span class="slds-checkbox">
                  <input type="checkbox" name="newsletter-options" id="input-newsletter-OptIn" value="off"> 
                  <label class="slds-checkbox__label" for="input-newsletter-OptIn">
                    <span class="slds-checkbox_faux"></span>
                    <span id="label-newsletter" class="slds-form-element__label">Please include me on your newsletter list</span>
                  </label></input>
                </span>
              </div>
            </div>

            <!-- Anonymous Donation -->
            <div data-reactroot="" id="anonymousDonorSection" class="slds-form-element slds-m-top--medium">
              <div class="slds-form-element__control">
                <span class="slds-checkbox">
                  <input type="checkbox" name="anonymous-options" id="anonymous-OptIn" value="off"> 
                  <label class="slds-checkbox__label" for="anonymous-OptIn">
                    <span class="slds-checkbox_faux"></span>
                    <span id="label-anonymous" class="slds-form-element__label">Please make this donation Anonymous</span>
                  </label></input>
                </span>
              </div>
            </div>

            <!-- Optional Language Preference Picklist -->
            <div id="languagePreferenceSection">
              <div class="slds-form-element slds-m-top--medium" id="languagePreferenceSelect">
                <label id="label-languagePreferenceSelect" class="slds-form-element__label" for="languagePreferenceSelect">Please select preferred correspondence language</label>
                <div class="slds-form-element__control">
                  <div class="slds-select_container">
                    <select id="input-languagePreferenceSelectOption" class="slds-select"> 
                      <option selected="selected" >en</option>
                      <option >fr</option> 
                    </select>
                  </div>
                </div>
              </div> 
            </div>

          </fieldset>
      
          <!-- Next Button -->
          <div class="slds-grid slds-grid--align-center">
            <button type="button" id="button-donorProceedToDonation" class="slds-button slds-button--brand slds-m-top--medium" 
              onclick="loadPage('donationType')">Next to Donation Type</button>                          
          </div>

          <div align="center" style="color:red" id="message-donorInformationError" class="slds-m-top--medium"> Please complete all mandatory fields </div> 
          <div align="center" class="slds-text-color_default slds-m-top--small" id="message-individualDonor"> An electronic tax receipt in the name of the <b>Donor</b> will be sent to the email address provided. </div>
          <div align="center" class="slds-text-color_default slds-m-top--small" id="message-organizationDonor"> An electronic tax receipt in the name of the <b>Company</b> will be sent to the contact email address provided. </div>
    
        </div> 
      </div>
    </div>
    <!-- end donorInformationPage -->

    <!-- donationTypePage --> 
    <div id="donationTypePage">
      <div class="myapp slds-p-horizontal--medium">
        <div class="slds-form--stacked slds-m-top--small">
          <fieldset class="slds-form--compound " id="donationAmountFields">

            <!-- One-Time / Recurring Option -->
            <legend id="label-giftType" class="slds-form-element__legend slds-form-element__label slds-text-title--caps ">Make my gift</legend>
            <div class="slds-form-element__control">
              <div class="slds-radio_button-group">
                <span class="slds-button slds-radio_button">
                  <input type="radio" name="donationFrequencyOptions" id="input-radio-onetime" value="onetime" checked="true">
                  <label class="slds-radio_button__label" for="input-radio-onetime"> <span id="label-onetimeGift" class="slds-radio_faux">One-Time</span> </label> </input>
                </span>
                <span class="slds-button slds-radio_button">
                  <input type="radio" name="donationFrequencyOptions" id="input-radio-recurring" value="recurring"> 
                  <label class="slds-radio_button__label" for="input-radio-recurring"> <span id="label-recurringGift" class="slds-radio_faux">Recurring</span> </label> </input>
                </span>
              </div>
            </div>

            <!-- Recurring Frequency Picklist -->
            <div class="slds-form-element slds-m-top--medium" id="recurringFrequencySelect">
              <label id="label-recurringGiftFrequency" class="slds-form-element__label" for="recurringFrequencySelect">Recurring Gift Frequency</label>
              <div class="slds-form-element__control">
                <div class="slds-select_container">
                  <select id="input-recurringGiftFrequencyOption" class="slds-select"> 
                    <option >Annually</option> 
                    <option >Quarterly</option> 
                    <option selected="selected" >Monthly</option>
                    <option >Weekly</option> 
                    <option >Daily</option> 
                  </select>
                </div>
              </div>
            </div>         

            <!-- CUSTOM:  One-Time Donation Amounts and Labels -->
            <div id="onetimeGiftOptions">
              <legend id="label-onetimeGiftAmount" class="slds-form-element__legend slds-form-element__label slds-m-top--medium">I will give a <b>One-time</b> gift of:</legend>
              <div class="slds-form-element__control">
                <span class="slds-radio">
                  <input type="radio" id="onetime-option-1" name="options" value="on" onChange="document.getElementById('input-amount').value=50"/>
                  <label class="slds-radio__label" for="onetime-option-1">
                    <span class="slds-radio_faux"></span>
                    <span id="label-onetime-option-1" class="slds-form-element__label">$50 Can buy a grab bar for safety in the bathroom</span>
                  </label>
                </span>
                <span class="slds-radio">
                  <input type="radio" id="onetime-option-2" name="options" value="on" onChange="document.getElementById('input-amount').value=100"/>
                  <label class="slds-radio__label" for="onetime-option-2">
                    <span class="slds-radio_faux"></span>
                    <span id="label-onetime-option-2" class="slds-form-element__label">$100 Can raise a toilet for safety in the bathroom</span>
                  </label>
                </span>
                <span class="slds-radio">
                  <input type="radio" id="onetime-option-3" name="options" value="on" onChange="document.getElementById('input-amount').value=250"/>
                  <label class="slds-radio__label" for="onetime-option-3">
                    <span class="slds-radio_faux"></span>
                    <span id="label-onetime-option-3" class="slds-form-element__label">$250 Can buy a stander pole for safety in the home</span>
                  </label>
                </span>
                 <!-- CUSTOM: Added option 4 -->
                <span class="slds-radio">
                  <input type="radio" id="onetime-option-4" name="options" value="on" onChange="document.getElementById('input-amount').value=500"/>
                  <label class="slds-radio__label" for="onetime-option-4">
                    <span class="slds-radio_faux"></span>
                    <span id="label-onetime-option-4" class="slds-form-element__label">$500 Can provide a ramp, grab bars, and a stander pole</span>
                  </label>
                </span>
              </div>
            </div>
             <!-- CUSTOM:  Recurring Donation Amounts and Labels -->
            <div id="recurringGiftOptions">
              <legend id="label-recurringGiftAmount" class="slds-form-element__legend slds-form-element__label slds-m-top--medium">I will give a <b>Recurring</b> gift of:</legend>
              <div class="slds-form-element__control">
                <span class="slds-radio">
                  <input type="radio" id="recurring-option-1" name="options" value="on" onChange="document.getElementById('input-amount').value=10"/>
                  <label class="slds-radio__label" for="recurring-option-1">
                    <span class="slds-radio_faux"></span>
                    <span id="label-recurring-option-1" class="slds-form-element__label">$10 monthly can purchase 3 grab bars, offering stability in the bathroom</span>
                  </label>
                </span>
                <span class="slds-radio">
                  <input type="radio" id="recurring-option-2" name="options" value="on" onChange="document.getElementById('input-amount').value=27"/>
                  <label class="slds-radio__label" for="recurring-option-2">
                    <span class="slds-radio_faux"></span>
                    <span id="label-recurring-option-2" class="slds-form-element__label">$27 monthly can provide a ramp for home and community access</span>
                  </label>
                </span>
                <span class="slds-radio">
                  <input type="radio" id="recurring-option-3" name="options" value="on" onChange="document.getElementById('input-amount').value=40"/>
                  <label class="slds-radio__label" for="recurring-option-3">
                    <span class="slds-radio_faux"></span>
                    <span id="label-recurring-option-3" class="slds-form-element__label">$40 monthly can widen a door frame for getting from room to room independently</span>
                  </label>
                </span>
                <!-- CUSTOM: Added options 4 and 5 -->
                <span class="slds-radio">
                  <input type="radio" id="recurring-option-4" name="options" value="on" onChange="document.getElementById('input-amount').value=83"/>
                  <label class="slds-radio__label" for="recurring-option-4">
                    <span class="slds-radio_faux"></span>
                    <span id="label-recurring-option-4" class="slds-form-element__label">$83 monthly can provide hard flooring in one room for navigating with ease</span>
                  </label>
                </span>
                <span class="slds-radio">
                  <input type="radio" id="recurring-option-5" name="options" value="on" onChange="document.getElementById('input-amount').value=200"/>
                  <label class="slds-radio__label" for="recurring-option-5">
                    <span class="slds-radio_faux"></span>
                    <span id="label-recurring-option-5" class="slds-form-element__label">$200 monthly can provide a stair glide for accessing all floors of the home</span>
                  </label>
                </span>
              </div>
            </div>
            <div>
              <span class="slds-radio">
                <input type="radio" id="other-option" name="options" value="on" />
                <label class="slds-radio__label" for="other-option">
                  <span class="slds-radio_faux"></span>
                  <span id="label-otherAmount" class="slds-form-element__label">Other Amount, Please specify:</span>
                  <input type="text" id="input-amount" class="slds-input slds-m-top--medium" />
                </label>
              </span>
            </div>

          </fieldset>

          <!-- Next/Back Button -->
          <div class="slds-grid slds-grid--align-center">
            <button type="button" id="button-donationTypePageBackToDonor" class="slds-button slds-button--brand slds-m-top--medium" 
              onclick="loadPage('donorInformation')">Back to Donor Info</button> 
            <button type="button" id="button-donationTypePageToPayment" class="slds-button slds-button--brand slds-m-top--medium" 
              onclick="loadPage('paymentInformation')">Next (Payment Info)</button>                  
          </div>
          <div align="center" style="color:red" id="message-donationTypeError" class="slds-m-top--medium"> Please select or enter a Gift Amount </div> 
          <div align="center" class="slds-text-color_default slds-m-top--small" id="message-donationTypeNotification"> Please select the frequency and amount of your gift </div>
        </div> 
      </div>
    </div>
    <!-- end donationTypePage -->  
    
    <!-- paymentInformationPage --> 
    <div id="paymentInformationPage">
      <div class="myapp slds-p-horizontal--medium">
        <div class="slds-form--stacked slds-m-top--medium">
          <legend id="label-donationInformation" class="slds-form-element__legend slds-form-element__label slds-text-title--caps slds-m-top--small">Donation Information</legend>
          <fieldset class="slds-form--compound slds-m-top--medium" id="donationInformationFields">
            <span id="firstNameField"> first name </span> <span id="lastNameField"> last name </span>
            <span> - </span> <span id="emailField"> email Address </span> 
            <span> - </span> <span id="amountField"> amount </span>
            <span id="message-giftType"> One-Time </span>     
      
            <!-- Method of Payment Selection -->
            <fieldset class="slds-form-element slds-m-top--medium">
              <legend id="label-MOP" class="slds-form-element__legend slds-form-element__label ">Method of Payment</legend>
              <div class="slds-form-element__control">
                <div class="slds-radio_button-group">
                  <div id="Cash-option">
                    <span class="slds-button slds-radio_button">
                      <input type="radio" name="mopOptions" id="input-radio-cash" value="Cash"  >
                      <label class="slds-radio_button__label" for="input-radio-cash"> <span id="label-cash" class="slds-radio_faux">Cash </span> </label> 
                    </input>
                    </span>
                  </div>
                  <div id="Check-option">
                    <span class="slds-button slds-radio_button">
                      <input type="radio" name="mopOptions" id="input-radio-check" value="Check"> 
                      <label class="slds-radio_button__label" for="input-radio-check"> <span id="label-check" class="slds-radio_faux">Check</span> </label> </input>
                    </span>
                </div>
                  <span class="slds-button slds-radio_button">
                    <input type="radio" name="mopOptions" id="input-radio-creditCard" value="credit card" checked="true"> 
                    <label class="slds-radio_button__label" for="input-radio-creditCard"> <span id="label-creditCard" class="slds-radio_faux">Credit Card</span> </label> </input>
                  </span>
                  <div id="ACH-option">
                    <span class="slds-button slds-radio_button">
                    <input type="radio" name="mopOptions" id="input-radio-ACH" value="ach" > 
                    <label class="slds-radio_button__label" for="input-radio-ACH"> <span id="label-ACH" class="slds-radio_faux">Direct Debit</span> </label> </input>
                  </span>
                </div>
                </div>
              </div>

              <!-- Check Information Input -->
              <div id="checkInfoSection" class="slds-form-element__group slds-m-top--medium" >
                <div class="slds-form-element__row slds-grid--pull-padded">
                  <div class="slds-p-horizontal--small slds-size--1-of-2 slds-medium-size--1-of-2 slds-large-size--1-of-2">
                    <label id="checkNumLabel" class="slds-form-element__label" for="input-checkNum">Check Number</label>
                    <input type="text" id="input-checkNum" class="slds-input" />
                  </div>
                  <div class="slds-p-horizontal--small slds-size--1-of-2 slds-medium-size--1-of-2 slds-large-size--1-of-2">
                    <label id="checkDateLabel" class="slds-form-element__label" for="input-checkDate">Check Date</label>
                    <input type="date" id="input-checkDate" class="slds-input" value=""/>
                  </div>
                </div>
              </div>

              <!-- Offline payment Dates -->
              <div id="closeDateSection" class="slds-m-top--medium">
                <label id="checkNumLabel" class="slds-form-element__label" for="input-offlinePaymentDate">Deposit Date</label>
                <div class="slds-form-element"> 
                  <input type="date" id="input-offlinePaymentDate" class="slds-input" value=""/>
                </div>
              </div>

              <!-- Receipt Options-->
              <div id="receiptOptionSection">
                <legend class="slds-form-element__legend slds-form-element__label slds-m-top--medium">Receipt Options</legend>
                <div class="slds-form-element__control">
                  <div class="slds-radio_button-group">
                    <span class="slds-button slds-radio_button">
                      <input type="radio" name="receiptOptions" id="input-receiptNow" value="receiptNow" checked="true" >

          'ô': 'o', // Lower case o with circumflex

          'Ù': 'U', // Upper case O with grave
          'ù': 'u', // Lower case o with grave
          'Ú': 'U', // Upper case O with acute
          'ú': 'u', // Lower case o with acute
          'Û': 'U', // Upper case O with circumflex
          'û': 'u' // Lower case o with circumflex
        };
    String.prototype.anglo = function() {
          return this.replace(/[^A-Za-z0-9]/g, function(x) { return URLString.french_map[x] || x; })
        };
        

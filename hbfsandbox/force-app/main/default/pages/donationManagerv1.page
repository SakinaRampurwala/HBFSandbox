    function checkEmptyValue(value) {
      var checkedValue = "";
      if(value !== undefined) { checkedValue = value; } 
      return checkedValue;
    } // end checkEmptyValue

    function checkInputField(inputFieldObject, fieldType="None") {
      var inputField = document.getElementById(inputFieldObject.fieldId);
      var inputFieldValue = inputField.value;
      var specialValidationOK = true;

      switch (fieldType)
      {
        case "email" :
          var inputFormElement = inputField;
          specialValidationOK = validateEmail(inputFieldValue);
        break;
        case "amount" :
          var inputFormElement = inputField;
          if (inputFieldValue === undefined ) { inputFieldObject.value = "";} 
          else { inputFieldValue = inputFieldValue.replace(/[^\d\.]/g,""); };
        break;
        case "checkbox" :
          var inputFormElement = document.getElementById(inputFieldObject.formElementId);
          inputFieldValue = inputField.checked;
          if(inputFieldObject.required && !inputField.checked) { specialValidationOK = false; }
        break;
        case "date" :
          var inputFormElement = inputField;
          specialValidationOK = validateDate(inputFieldValue);
        break; 
        default :   
          inputFormElement = inputField;
        break;
      }

        if(inputFieldValue === undefined || inputFieldValue.trim() === "") {
          inputFieldObject.value = "";
          if(inputFieldObject.required) {
            if ( !inputFormElement.className.match(/(?:^|\s)slds-has-error(?!\S)/) ) { inputFormElement.classList.toggle('slds-has-error'); }
            inputFieldObject.status = false;
          } else {
            if ( inputFormElement.className.match(/(?:^|\s)slds-has-error(?!\S)/) ) { inputFormElement.classList.toggle('slds-has-error'); }
            inputFieldObject.status = true;
          }
        } else {
          inputFieldObject.value = inputFieldValue;
          if(specialValidationOK) {
            if ( inputFormElement.className.match(/(?:^|\s)slds-has-error(?!\S)/) ) { inputFormElement.classList.toggle('slds-has-error'); }
            inputFieldObject.status = true;
          } else {
            if ( !inputFormElement.className.match(/(?:^|\s)slds-has-error(?!\S)/) ) { inputFormElement.classList.toggle('slds-has-error'); }
            inputFieldObject.status = false;
          }
        }
    } // end checkInputField

    function show(elementId, isDisabled="") {
      var inputField = document.getElementById(elementId);
      inputField.style.display='block';
      if(isDisabled === "disabled") { disable(elementId); } 
      else { enable(elementId); }
    } // end show

    function hide(elementId, isDisabled="") {
      var inputField = document.getElementById(elementId);
      inputField.style.display='none';
      if(isDisabled === "disabled") { disable(elementId); } 
      else { enable(elementId); }
    } // end hide

    function enable(elementId) {
      var inputField = document.getElementById(elementId);
      inputField.disabled=false;
    } // end enable

    function disable(elementId) {
      var inputField = document.getElementById(elementId);
      inputField.disabled=true;
    } // end disable


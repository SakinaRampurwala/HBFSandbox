  <!-- Stripe JavaScript -->
<script src="https://js.stripe.com/v3/"></script>

<script>

  var dFirstName, dlastName;
  if(getDonorType() == 'individual') {
    dFirstName = document.getElementById('input-donor-fName').value;
    dlastName = document.getElementById('input-donor-lName').value;
    } else { // Organization
      dFirstName = "Organization";
      dlastName = document.getElementById('input-organizationName').value;
  } 
  var cardStyle = { base: { fontSize: '18px',color: "#32325d", } };
  var stripe, elements, card;

  // Create a token or display an error when the form is submitted.
  var form = document.getElementById('payment-form');
  form.addEventListener('submit', function(event) {
    var dEmail = document.getElementById('input-donor-eMail').value; 
    document.getElementById("stripeButton").disabled = true;
    show("donateNowSpinner");
    event.preventDefault();

    if(getDonationTypeOption() == "onetime") {
      stripe.createToken(card).then(function(result) {
        if (result.error) {
          // Inform the customer that there was an error.
          var errorElement = document.getElementById('card-errors');
          errorElement.textContent = result.error.message;
          document.getElementById("stripeButton").disabled = false;
          hide("donateNowSpinner");
        } else {
          // Create Transaction record, Process Token and create Opportunity
          newStripeTransactionRecord(result.token.id, amountInputField.value);
        }
      });
    } else {
      stripe.createPaymentMethod({
        type: 'card',
        card: card,
        billing_details: {
          email: dEmail,
        },
      }).then(stripePaymentMethodHandler);
    }
  }); 

  function stripePaymentMethodHandler(result, email) {
    var dFirstName, dlastName;
    if(getDonorType() == 'individual') {
      dFirstName = document.getElementById('input-donor-fName').value;
      dlastName = document.getElementById('input-donor-lName').value;
    } else { // Organization
        dFirstName = "Organization";
        dlastName = document.getElementById('input-organizationName').value;
    } 
    var dEmail = document.getElementById('input-donor-eMail').value;
    var dName = dFirstName+' '+dlastName;

    if (result.error) {
      // Show error in payment form
    } else {
      // Otherwise send paymentMethod.id to your server
      newStripeCustomer(result.paymentMethod.id, dEmail, dName);
    } 
  } // end stripePaymentMethodHandler
  
  function setupStripe(formLanguage) {
    var stripeKey;
    Visualforce.remoting.Manager.invokeAction('{!$RemoteAction.donationManagerExtensionJS.getStripePublishableKey}',
    function(result, event){ 
      if (event.status) {
        stripeKey = result;
        disable("stripeButton");

        stripe = Stripe(stripeKey, { locale: formLanguage}); 
        elements = stripe.elements();  
        card = elements.create('card', { hidePostalCode: true, style: cardStyle });
        card.mount('#card-element');  // Add an instance of the card Element into the `card-element` <div>.
        card.addEventListener('change', function(event) {
          var displayError = document.getElementById('card-errors');
          if (event.error) { displayError.textContent = event.error.message; } else { displayError.textContent = ''; }
        });
        card.on('change', function(event) {
          if (event.complete) {
            enable("stripeButton");
          // } else if (event.error) {
          } else {
            disable("stripeButton");
          }
        });

      } else if (event.type === 'exception') {  document.getElementById("responseErrors").innerHTML = event.message + "<br/>\n<pre>" + event.where + "</pre>";
      } else { document.getElementById("responseErrors").innerHTML = event.message; } }, {escape: true}
    );  

  } // end setupStripe

  function newStripeTransactionRecord(stripeToken, amount) {
    Visualforce.remoting.Manager.invokeAction('{!$RemoteAction.donationManagerExtensionJS.newStripeTransactionRecord}',
    function(result, event){ 
        if (event.status) {
          var transactionRecordId = result;
          createNewStripeCharge(stripeToken, transactionRecordId, amount);
        } else if (event.type === 'exception') {  document.getElementById("responseErrors").innerHTML = event.message + "<br/>\n<pre>" + event.where + "</pre>";
        } else { document.getElementById("responseErrors").innerHTML = event.message; } }, {escape: true}
    );  
  } // end newStripeTransactionRecord
  
  function createNewStripeCharge(stripeToken, transactionRecordId, amount) {
    Visualforce.remoting.Manager.invokeAction('{!$RemoteAction.donationManagerExtensionJS.createNewStripeCharge}', stripeToken, transactionRecordId, amount,
    function(result, event){ 
        if (event.status) {
          var newChargeStatus = result;
          var stripeCustomerId = '';
          if(newChargeStatus == 'succeeded') {
            processStripePayment(transactionRecordId, stripeCustomerId);
          } else {
            hide("donateNowSpinner"); hide("processOnlinePaymentPageStripe"); show("stripeResultFailPage");
          }
        } else if (event.type === 'exception') {  document.getElementById("responseErrors").innerHTML = event.message + "<br/>\n<pre>" + event.where + "</pre>";
        } else { document.getElementById("responseErrors").innerHTML = event.message; } }, {escape: true}
    );  
  } // end createNewStripeCharge

  function newStripeCustomer(paymentMethod, email, name) {
    Visualforce.remoting.Manager.invokeAction('{!$RemoteAction.donationManagerExtensionJS.newStripeCustomer}', paymentMethod, email, name,
    function(result, event){ 
        if (event.status) {
          var stripeCustomerId = result;
          var transactionRecordId = '';
          processStripePayment(transactionRecordId, stripeCustomerId);
        } else if (event.type === 'exception') {  document.getElementById("responseErrors").innerHTML = event.message + "<br/>\n<pre>" + event.where + "</pre>";
        } else { document.getElementById("responseErrors").innerHTML = event.message; } }, {escape: true}
    );  
  } // end newStripeCustomer

  function createNewStripeSubscription(stripeCustomerId, rdId) {
    var recurringFrequency = getDonationFrequency();
    var recurringAmount = amountInputField.value;

    Visualforce.remoting.Manager.invokeAction('{!$RemoteAction.donationManagerExtensionJS.newStripeSubscription}', stripeCustomerId, recurringFrequency, recurringAmount, rdId,
    function(result, event){ 
        if (event.status) {
          // if(mode == "dm") { window.location.replace(siteURL+'/Fundraising?mode=dm'); //('https://cssproductiontest.secure.force.com/Fundraising');
          if(mode == "dm") { hide("donateNowSpinner"); hide("processOnlinePaymentPageStripe"); show("stripeResultOKPage"); 
            } else {  sforce.one.navigateToSObject(rdId); }
        } else if (event.type === 'exception') {  document.getElementById("responseErrors").innerHTML = event.message + "<br/>\n<pre>" + event.where + "</pre>";
        } else { document.getElementById("responseErrors").innerHTML = event.message; } }, {escape: true}
    );
  } // end createNewStripeSubscription

</script>
<!-- / Stripe JavaScript --> 


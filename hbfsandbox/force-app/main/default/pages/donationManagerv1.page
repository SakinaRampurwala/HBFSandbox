    function populateCampaign(){
      var selectIndex = 0;

      var modeVal = "";
      if( mode === "dm") {modeVal = "donationManagerOnline"} else {modeVal = "donationManager"}

      if (cid == null) {  // Check to see if a Campaign ID has been provided in the URL
        Visualforce.remoting.Manager.invokeAction('{!$RemoteAction.donationManagerExtensionJS.getCampaignsByMode}', modeVal,
         function(result, event){
          var select = document.getElementById("input-campaignSelectOption"); 
          select.remove(0); // Remove placeholder
          if (event.status) {
            for (var c in event.result) {
              var el = document.createElement("option");

              // Added to support Bilingual
              if(lang == 'fr'){ el.textContent = event.result[c].bilingualCampaignName; } 
              else { el.textContent = event.result[c].Name; } 

              el.value = event.result[c].Id;
              select.appendChild(el);
              if(event.result[c].defaultCampaign) {
                selectIndex = c;
              }
            }
            document.getElementById("input-campaignSelectOption").selectedIndex = selectIndex;
          } else if (event.type === 'exception') { document.getElementById("responseErrors").innerHTML = event.message + "<br/>\n<pre>" + event.where + "</pre>";
          } else { document.getElementById("responseErrors").innerHTML = event.message; } }, {escape: true}
        );
      } else {
        hide("campaignSelectSection");  //if cid not null hide the HTML div for the Campaign Picklist
      }
    } // end populateCampaign

